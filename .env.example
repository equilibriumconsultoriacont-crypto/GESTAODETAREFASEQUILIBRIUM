# Copie este arquivo para .env e preencha com os valores reais.
# Os valores de produção estão no painel do Render → Environment.
# NUNCA commite o .env (ele já está no .gitignore).

# --- Banco (obrigatório) ---
# String de conexão do MySQL no Aiven.
DATABASE_URL=mysql://usuario:senha@host:porta/banco?ssl-mode=REQUIRED

# --- Aplicação (obrigatório) ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Sessão / autenticação (obrigatório) ---
# Em desenvolvimento pode ser qualquer string longa e aleatória.
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
SESSION_SECRET=troque-por-uma-string-longa-e-aleatoria

# Secret usado pelo endpoint POST /admin/setup (migrações).
MIGRATE_SECRET=troque-por-uma-string-longa-e-aleatoria

# --- E-mail (opcional em dev; sem isso o envio falha, o resto funciona) ---
# Se RESEND_API_KEY estiver definida, usa Resend; senão cai para SMTP.
RESEND_API_KEY=
RESEND_FROM=contato@seudominio.com.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Equilíbrio Consultoria
SMTP_CC_EMAIL=

# --- Integrações opcionais ---
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
